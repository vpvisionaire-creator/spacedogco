---
// SwissKnife.astro — SIGNATURE OBJECT (real artwork)
// Built from the SPCDG_Knife (.ai) layers: 8 blade PNGs + handle, each
// positioned exactly as in the source and rotated about the real hinge.
// GSAP folds them closed, then deploys each from closed→open on scroll.
import { BLADES } from "../data/site.js";
import layout from "../data/knife_layout.json";

const L = layout.layers;
const order = ["branding","social","campaigns","commercials","music","editorial","docu","interview"];
const bladeMeta = (id) => BLADES.find((b) => b.id === id);
---

<div class="knife" id="knife" role="img"
     aria-label="The Spacedog Swiss Army knife — eight capabilities, one tool.">

  <!-- HUD radar rings behind the knife -->
  <svg class="knife-rings" viewBox="0 0 100 72" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <g stroke="var(--color-gray)" fill="none" stroke-width="0.18">
      <circle cx="50.7" cy="50.4" r="14"/>
      <circle cx="50.7" cy="50.4" r="22"/>
      <circle cx="50.7" cy="50.4" r="30"/>
      <circle cx="50.7" cy="50.4" r="38"/>
      <line x1="50.7" y1="4" x2="50.7" y2="70"/>
      <line x1="10" y1="50.4" x2="92" y2="50.4"/>
    </g>
  </svg>

  <!-- HUD connector lines (drawn per blade by GSAP/CSS) -->
  <svg class="knife-lines" viewBox="0 0 100 72" preserveAspectRatio="none" aria-hidden="true"></svg>

  <!-- Layered artwork. transform-origin = real hinge for each piece. -->
  <div class="knife-stage">
    {order.map((id) => {
      const p = L[id];
      return (
        <img
          class="blade"
          data-blade={id}
          data-open={p.open}
          src={`/media/knife/${id}.png`}
          alt=""
          loading="eager"
          style={`
            left:${p.left_pct}%; top:${p.top_pct}%;
            width:${p.w_pct}%;
            transform-origin:${p.origin_x_pct}% ${p.origin_y_pct}%;
          `}
        />
      );
    })}
    <!-- handle on top, hides hinge overlap + pulses on deploy -->
    <img
      class="knife-handle"
      src="/media/knife/handle.png"
      alt=""
      loading="eager"
      style={`
        left:${L.handle.left_pct}%; top:${L.handle.top_pct}%;
        width:${L.handle.w_pct}%;
        transform-origin:${L.handle.origin_x_pct}% ${L.handle.origin_y_pct}%;
      `}
    />
  </div>

  <!-- HUD capability labels -->
  <div class="knife-labels">
    {order.map((id, i) => {
      const m = bladeMeta(id);
      return (
        <div class={`klabel klabel--${id}`} data-label={id} tabindex="0">
          <span class="klabel-id mono mission-id">CAP-{String(i + 1).padStart(2, "0")}</span>
          <span class="klabel-name">{m.name}</span>
          <span class="klabel-tip">{m.tip}</span>
        </div>
      );
    })}
  </div>
</div>

<style>
  .knife {
    position: relative;
    width: 100%;
    max-width: 980px;
    margin-inline: auto;
    aspect-ratio: 1.3914;   /* matches source canvas 5012x3602 */
  }
  .knife-rings, .knife-lines {
    position: absolute; inset: 0; width: 100%; height: 100%;
    opacity: 0.5; pointer-events: none;
  }
  .knife-stage { position: absolute; inset: 0; }

  .blade, .knife-handle {
    position: absolute;
    will-change: transform, opacity, filter;
    pointer-events: none;
  }
  /* Blades start folded (closed) + invisible; GSAP deploys them. */
  .blade { opacity: 0; }
  .blade.is-active { filter: drop-shadow(0 0 14px rgba(107,79,187,0.9)); }

  .knife-handle { z-index: 5; }

  /* --- Labels --- */
  .knife-labels { position: absolute; inset: 0; pointer-events: none; }
  .klabel {
    position: absolute; pointer-events: auto; cursor: default;
    opacity: 0; transform: translateY(6px);
    display: flex; flex-direction: column; gap: 3px; max-width: 190px;
    transition: opacity var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out);
  }
  .klabel.is-in { opacity: 1; transform: none; }
  .klabel-name {
    font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.07em;
    text-transform: uppercase; color: var(--color-white); line-height: 1.25;
  }
  .klabel-tip {
    font-size: 12px; color: var(--color-offwhite); opacity: 0; max-height: 0;
    overflow: hidden; transition: opacity var(--dur-fast) var(--ease-out), max-height var(--dur-fast) var(--ease-out);
  }
  .klabel:hover, .klabel:focus-visible { outline: none; }
  .klabel:hover .klabel-name, .klabel:focus-visible .klabel-name,
  .klabel.is-active .klabel-name { color: var(--color-purple-lt); }
  .klabel:hover .klabel-tip, .klabel:focus-visible .klabel-tip,
  .klabel.is-active .klabel-tip { opacity: 0.9; max-height: 90px; }

  /* Label anchors mirror the deployed fan */
  .klabel--branding    { top: 4%;  left: 8%; }
  .klabel--social      { top: 0%;  left: 40%; }
  .klabel--campaigns   { top: 14%; right: 4%; text-align: right; align-items: flex-end; }
  .klabel--commercials { top: 52%; right: 0%; text-align: right; align-items: flex-end; }
  .klabel--music       { bottom: 12%; right: 6%; text-align: right; align-items: flex-end; }
  .klabel--editorial   { bottom: 0%; left: 46%; }
  .klabel--docu        { bottom: 6%; left: 8%; }
  .klabel--interview   { top: 46%; left: 0%; }

  @media (max-width: 768px) {
    .knife { max-width: 580px; }
    .klabel { max-width: 110px; }
    .klabel-tip { display: none; }
    .klabel-name { font-size: 10px; }
  }
</style>
