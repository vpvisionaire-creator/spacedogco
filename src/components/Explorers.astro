---
// Section 05 — The Explorers. Cinematic philosophy + parallax.
---
<section class="section explorers">
  <div class="explorers-bg" data-parallax="0.6" aria-hidden="true">
    <img src="/media/explorers.svg" alt="" loading="lazy" decoding="async" />
  </div>
  <div class="explorers-overlay"></div>
  <div class="hud-corners"><span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span></div>
  <span class="hud-coord top mono">FRONTIER / OPEN</span>

  <div class="wrap explorers-content">
    <span class="mono mission-id" data-reveal>PHILOSOPHY / SYS-05</span>
    <h2 class="display" data-reveal data-delay="0.05">The Explorers</h2>
    <p class="explorers-copy" data-reveal data-delay="0.1">
      We are always in search of the next frontier. Trying new things.
      Exploring different worlds. Taking inspiration from beyond what is expected.
    </p>
  </div>
</section>

<style>
  .explorers {
    position: relative; min-height: 100vh; display: flex; align-items: center;
    overflow: hidden; padding-block: var(--space-2xl);
  }
  .explorers-bg { position: absolute; inset: -10% 0; z-index: 0; }
  .explorers-bg img { width: 100%; height: 120%; object-fit: cover; }
  .explorers-overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg, rgba(10,9,8,0.92) 0%, rgba(10,9,8,0.55) 60%, rgba(10,9,8,0.8) 100%);
  }
  .explorers-content { position: relative; z-index: 3; max-width: 720px; }
  .explorers h2 { margin: 14px 0 var(--space-md); }
  .explorers-copy { font-size: clamp(18px, 2.6vw, 26px); line-height: 1.5; color: var(--color-offwhite); }
</style>
