---
// Section 01 — Hero. Spacedog space station / mission bay.
import Toolbox from "./Toolbox.astro";
---
<section class="hero" data-hero>
  <!-- Space station environment (layered, parallax-ready) -->
  <div class="station" aria-hidden="true">
    <div class="station-grid"></div>
    <div class="station-glow"></div>
    <div class="station-rib station-rib--l"></div>
    <div class="station-rib station-rib--r"></div>
    <div class="station-window">
      <div class="stars"></div>
    </div>
  </div>

  <!-- HUD frame -->
  <div class="hud-corners"><span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span></div>
  <span class="hud-coord top mono">LAT 40.7128° N</span>
  <span class="hud-coord top-right mono">LON 74.0060° W</span>
  <span class="hero-bay-id mono">SPCDG / MISSION-BAY 02 / STATUS: ONLINE</span>

  <div class="hero-content wrap">
    <div class="hero-copy">
      <img class="hero-symbol" src="/media/brand/symbol.png" alt="Spacedog" width="84" height="92" data-hero-item />
      <h1 class="display hero-title" data-hero-item>
        The Swiss Army knife<br/>of the creative space.
      </h1>
      <p class="mono hero-sub" data-hero-item>NYC Based Creative Production Agency</p>
      <div class="hero-actions" data-hero-item>
        <a href="/contact" class="btn btn--solid">Start a Project</a>
        <button class="hero-open mono" data-toolbox-trigger>Open the toolbox ↓</button>
      </div>
    </div>

    <!-- The toolbox: the object that triggers the deployment -->
    <button class="hero-toolbox" data-toolbox-trigger aria-label="Open the toolkit" data-hero-item>
      <Toolbox />
      <span class="hero-toolbox-pulse"></span>
      <span class="mono hero-toolbox-hint">CLICK TO DEPLOY</span>
    </button>
  </div>

  <span class="hero-scroll mono" data-scroll-hint>SCROLL ↓</span>
</section>

<style>
  .hero {
    position: relative; min-height: 100vh;
    display: flex; align-items: center;
    padding: var(--nav-h) var(--gutter) var(--space-lg);
    overflow: hidden;
    background: radial-gradient(120% 90% at 50% 20%, #16121f 0%, #0A0908 60%);
  }

  /* --- Station environment --- */
  .station { position: absolute; inset: 0; z-index: 0; }
  .station-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(107,79,187,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(107,79,187,0.06) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(80% 70% at 50% 50%, #000 30%, transparent 80%);
  }
  .station-glow {
    position: absolute; left: 50%; top: 16%; width: 70vw; height: 50vh;
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(107,79,187,0.18), transparent 60%);
    filter: blur(20px);
  }
  .station-rib {
    position: absolute; top: 0; bottom: 0; width: 14vw; min-width: 90px;
    background: linear-gradient(90deg, rgba(20,16,28,0.9), rgba(10,9,8,0));
    border-right: 1px solid rgba(107,79,187,0.14);
  }
  .station-rib--l { left: 0; }
  .station-rib--r { right: 0; transform: scaleX(-1); }
  .station-window {
    position: absolute; left: 50%; top: 10%; transform: translateX(-50%);
    width: 44vw; height: 44vh; border: 1px solid rgba(107,79,187,0.22);
    border-radius: 50% 50% 46% 46%;
    box-shadow: inset 0 0 80px rgba(107,79,187,0.12);
    overflow: hidden;
  }
  .stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, #fff, transparent),
      radial-gradient(1px 1px at 60% 70%, #cfc7e8, transparent),
      radial-gradient(1.5px 1.5px at 80% 20%, #fff, transparent),
      radial-gradient(1px 1px at 35% 80%, #fff, transparent),
      radial-gradient(1px 1px at 75% 50%, #b9aee0, transparent);
    opacity: 0.7;
  }

  /* --- Content --- */
  .hero-content {
    position: relative; z-index: 3;
    display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-xl);
    align-items: center;
  }
  .hero-symbol { margin-bottom: var(--space-md); filter: drop-shadow(0 0 12px rgba(107,79,187,0.4)); }
  .hero-title { margin-bottom: 20px; }
  .hero-sub { color: var(--color-offwhite); margin-bottom: var(--space-md); }
  .hero-actions { display: flex; align-items: center; gap: var(--space-md); flex-wrap: wrap; }
  .hero-open {
    font-size: 11px; letter-spacing: 0.1em; color: var(--color-offwhite);
    border-bottom: 1px solid transparent; padding-bottom: 2px;
    transition: color var(--dur-fast), border-color var(--dur-fast);
  }
  .hero-open:hover { color: var(--color-purple-lt); border-color: var(--color-purple); }

  .hero-toolbox {
    position: relative; display: flex; flex-direction: column; align-items: center; gap: 14px;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .hero-toolbox:hover { transform: translateY(-6px); }
  .hero-toolbox-pulse {
    position: absolute; top: 40%; left: 50%; width: 60%; aspect-ratio: 1;
    transform: translate(-50%,-50%); border-radius: 50%;
    background: radial-gradient(circle, rgba(107,79,187,0.35), transparent 65%);
    animation: tbPulse 2.6s var(--ease-in-out) infinite; pointer-events: none; z-index: -1;
  }
  .hero-toolbox-hint { color: var(--color-purple-lt); font-size: 10px; }
  @keyframes tbPulse { 0%,100%{opacity:0.4;transform:translate(-50%,-50%) scale(0.9);} 50%{opacity:0.8;transform:translate(-50%,-50%) scale(1.05);} }

  .hero-scroll {
    position: absolute; z-index: 3; left: 50%; bottom: 22px; transform: translateX(-50%);
    color: var(--color-offwhite); font-size: 10px;
  }

  @media (max-width: 860px) {
    .hero-content { grid-template-columns: 1fr; gap: var(--space-lg); text-align: left; }
    .hero-toolbox { align-self: center; max-width: 260px; }
    .station-window { width: 70vw; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-toolbox-pulse { animation: none; }
  }
</style>
