---
// Section 03 — Toolkit. SIGNATURE MOMENT. Pinned + scrubbed by GSAP.
// Phase 1: toolbox + scattered chaos tags. Phase 2: knife appears.
// Phase 3: blades deploy one by one. Then headline.
import SwissKnife from "./SwissKnife.astro";
const CHAOS = [
  "Branding", "Commercials", "Music Videos", "Editorial", "Docu",
  "Social", "Campaigns", "Photography", "Live", "Interviews",
  "Post", "Creative Direction", "Experiential", "Production",
];
---
<section class="toolkit" id="toolkit-section">
  <div class="hud-corners"><span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span></div>

  <div class="toolkit-stage wrap">
    <!-- Phase 1: the problem — creative chaos -->
    <div class="chaos" data-chaos aria-hidden="true">
      {CHAOS.map((c) => <span class="chaos-tag mono" data-chaos-tag>{c}</span>)}
    </div>
    <div class="toolbox" data-toolbox aria-hidden="true">
      <svg viewBox="0 0 160 120" width="160" height="120">
        <rect x="10" y="44" width="140" height="66" rx="5" fill="#b3261e" stroke="#0A0908" stroke-width="3"/>
        <rect x="10" y="44" width="140" height="16" fill="#8e1d17"/>
        <path d="M54 44 v-12 a6 6 0 0 1 6 -6 h40 a6 6 0 0 1 6 6 v12" fill="none" stroke="#b3261e" stroke-width="8"/>
        <rect x="70" y="66" width="20" height="10" rx="2" fill="#0A0908"/>
      </svg>
      <span class="mono">PROBLEM / MANY NEEDS</span>
    </div>

    <!-- Phase 2 + 3: the solution -->
    <SwissKnife />
  </div>

  <div class="toolkit-headline" data-knife-headline>
    <h2 class="display">The Swiss Army knife of the creative space.</h2>
    <p class="mono mission-id">We make it easy.</p>
  </div>
</section>

<style>
  .toolkit {
    position: relative; min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: var(--space-lg) var(--gutter);
    overflow: hidden;
  }
  .toolkit-stage { position: relative; display: grid; place-items: center; width: 100%; }

  .chaos {
    position: absolute; inset: 0; z-index: 1;
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 14px 22px; padding: 8%; pointer-events: none;
  }
  .chaos-tag {
    color: var(--color-offwhite); font-size: 13px; opacity: 0;
    border: 1px solid var(--color-gray); padding: 6px 12px;
  }
  .toolbox {
    position: absolute; z-index: 2; display: flex; flex-direction: column;
    align-items: center; gap: 10px; opacity: 0;
  }
  .toolbox .mono { color: var(--color-purple); }

  .toolkit-headline {
    position: relative; z-index: 4; text-align: center; margin-top: var(--space-lg);
    opacity: 0; max-width: 900px;
  }
  .toolkit-headline h2 { margin-bottom: 12px; }
</style>
