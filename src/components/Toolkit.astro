---
// Section 03 — Toolkit. SIGNATURE MOMENT. Pinned + scrubbed by GSAP.
// Phase 1: toolbox opens, capability chaos scatters. Phase 2: knife centers.
// Phase 3: real blades deploy from the hinge, labels + handle pulse.
import SwissKnife from "./SwissKnife.astro";
import Toolbox from "./Toolbox.astro";
const CHAOS = [
  "Branding", "Commercials", "Music Videos", "Editorial", "Docu",
  "Social", "Campaigns", "Photography", "Live", "Interviews",
  "Post", "Creative Direction", "Experiential", "Production",
];
---
<section class="toolkit" id="toolkit-section">
  <div class="hud-corners"><span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span></div>
  <span class="hud-coord top mono">SPCDG / TOOLKIT / DEPLOY SEQUENCE</span>

  <div class="toolkit-stage wrap">
    <!-- Phase 1: the problem — creative chaos pouring out of the toolbox -->
    <div class="chaos" data-chaos aria-hidden="true">
      {CHAOS.map((c) => <span class="chaos-tag mono" data-chaos-tag>{c}</span>)}
    </div>
    <div class="toolbox-holder" data-toolbox>
      <Toolbox open={true} />
      <span class="mono toolbox-cap">PROBLEM / MANY NEEDS</span>
    </div>

    <!-- Phase 2 + 3: the solution -->
    <SwissKnife />
  </div>

  <div class="toolkit-headline" data-knife-headline>
    <h2 class="display">The Swiss Army knife of the creative space.</h2>
    <p class="mono mission-id">We make it easy.</p>
  </div>
</section>

<style>
  .toolkit {
    position: relative; min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: var(--space-lg) var(--gutter);
    overflow: hidden;
  }
  .toolkit-stage { position: relative; display: grid; place-items: center; width: 100%; min-height: 70vh; }

  .chaos {
    position: absolute; inset: 0; z-index: 1;
    display: flex; flex-wrap: wrap; align-items: center; justify-content: center;
    gap: 14px 22px; padding: 6%; pointer-events: none;
  }
  .chaos-tag {
    color: var(--color-offwhite); font-size: 13px; visibility: hidden;
    border: 1px solid var(--color-gray); padding: 6px 12px; background: rgba(10,9,8,0.6);
  }
  .toolbox-holder {
    position: absolute; z-index: 2; display: flex; flex-direction: column;
    align-items: center; gap: 12px; visibility: hidden; max-width: 300px;
  }
  .toolbox-cap { color: var(--color-purple); }

  .toolkit-headline {
    position: relative; z-index: 6; text-align: center; margin-top: var(--space-lg);
    opacity: 0; max-width: 900px;
  }
  .toolkit-headline h2 { margin-bottom: 12px; }
</style>
