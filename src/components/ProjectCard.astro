---
// Reusable mission card.
const { project, index, showDescriptor = true } = Astro.props;
const num = String(index + 1).padStart(2, "0");
---
<a class="card" href={`/work/${project.id}`} data-reveal>
  <div class="card-media">
    <span class="card-num mono">{num}</span>
    <img src={project.media} alt={project.title} loading="lazy" decoding="async" />
    <div class="card-overlay"></div>
  </div>
  <div class="card-meta">
    <span class="mono mission-id">{project.category}</span>
    <h3 class="card-title display">{project.title}</h3>
    {showDescriptor && <p class="card-desc">{project.descriptor}</p>}
  </div>
</a>

<style>
  .card { display: block; }
  .card-media {
    position: relative; aspect-ratio: 16 / 10; overflow: hidden;
    background: var(--color-gray);
  }
  .card-num { position: absolute; top: 14px; left: 14px; z-index: 2; color: var(--color-gray-lt); opacity: 0.5; }
  .card-media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .card-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,9,8,0.55), transparent 60%);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .card:hover .card-media img { transform: scale(1.03); }
  .card:hover .card-overlay { background: linear-gradient(to top, rgba(10,9,8,0.7), rgba(74,52,133,0.12)); }
  .card-meta { padding-top: 16px; }
  .card-title { font-size: clamp(20px, 2.4vw, 28px); margin: 6px 0; }
  .card:hover .card-title { color: var(--color-white); }
  .card-desc { color: var(--color-offwhite); font-size: 14px; }
  @media (prefers-reduced-motion: reduce) {
    .card:hover .card-media img { transform: none; }
  }
</style>
