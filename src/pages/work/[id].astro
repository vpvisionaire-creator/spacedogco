---
import Base from "../../layouts/Base.astro";
import { PROJECTS } from "../../data/site.js";

export function getStaticPaths() {
  return PROJECTS.map((p, i) => {
    const next = PROJECTS[(i + 1) % PROJECTS.length];
    return { params: { id: p.id }, props: { project: p, index: i, next } };
  });
}
const { project, index, next } = Astro.props;
const cap = String(index + 1).padStart(2, "0");
---
<Base current="/work" title={`${project.title} — Spacedog`} description={project.descriptor}>
  <article class="project">
    <div class="project-hero">
      <img src={project.media} alt={project.title} />
      <div class="project-hero-overlay"></div>
      <span class="hud-coord top mono mission-id">{project.category} / CAP-{cap}</span>
      <div class="wrap project-hero-title">
        <h1 class="display">{project.title}</h1>
      </div>
    </div>

    <div class="section wrap project-body">
      <div class="project-data" data-reveal>
        <div><span class="mono mission-id">Client</span><p>{project.title.split(" x ")[0]}</p></div>
        <div><span class="mono mission-id">Category</span><p>{project.category}</p></div>
        <div><span class="mono mission-id">Role</span><p>Production + Post</p></div>
      </div>
      <p class="lead project-desc" data-reveal data-delay="0.05">{project.descriptor}</p>
      <p class="project-note mono">Replace with real project copy, embedded reel, and gallery.</p>

      <div class="project-media" data-reveal>
        <div class="media-placeholder mono">VIDEO / IMAGE GALLERY</div>
      </div>

      <a href={`/work/${next.id}`} class="project-next display" data-reveal>
        Next Mission → <span>{next.title}</span>
      </a>
    </div>
  </article>
</Base>

<style>
  .project-hero { position: relative; height: 80vh; overflow: hidden; }
  .project-hero img { width: 100%; height: 100%; object-fit: cover; }
  .project-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,9,8,0.9), transparent 60%); }
  .project-hero-title { position: absolute; left: 50%; transform: translateX(-50%); bottom: var(--space-lg); z-index: 2; }
  .project-body { max-width: 860px; }
  .project-data { display: flex; gap: var(--space-lg); flex-wrap: wrap; border-bottom: 1px solid var(--color-gray); padding-bottom: var(--space-md); margin-bottom: var(--space-md); }
  .project-data p { font-size: 16px; margin-top: 4px; }
  .project-desc { margin-bottom: 8px; }
  .project-note { color: var(--color-gray); font-size: 10px; }
  .media-placeholder {
    aspect-ratio: 16/9; background: var(--color-gray); margin: var(--space-lg) 0;
    display: grid; place-items: center; color: var(--color-offwhite); opacity: 0.6;
  }
  .project-next { display: inline-block; font-size: clamp(22px, 4vw, 40px); margin-top: var(--space-md); }
  .project-next span { color: var(--color-purple); }
  .project-next:hover span { color: var(--color-purple-dk); }
</style>
